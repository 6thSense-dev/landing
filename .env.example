# Backend (FastAPI) environment. Copy to `.env` and fill in for local dev.
# In production these are set as Railway service variables — never commit real values.

# Postgres connection string. Railway injects it as ${{Postgres.DATABASE_URL}}.
# DATABASE_URL=postgresql://user:pass@localhost:5432/sixthsense

# Comma-separated origins allowed for CORS + the Origin CSRF check.
# SENSEPROBE_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Rate limits (slowapi syntax). Defaults: leads 5/minute, login 10/minute.
# SENSEPROBE_RATE_LIMIT=5/minute
# SENSEPROBE_LOGIN_RATE_LIMIT=10/minute

# Set to false only for local HTTP dev so the session cookie is sent without TLS.
# SENSEPROBE_COOKIE_SECURE=true

# Founder portal seed accounts (consumed once by alembic migration 0003).
# Password must be >= 12 chars. Repeat for FOUNDER_2_*, FOUNDER_3_*, FOUNDER_4_*.
# FOUNDER_1_EMAIL=founder@6thsense.dev
# FOUNDER_1_NAME=Founder One
# FOUNDER_1_PASSWORD=change-me-please

# Frontend build-time API base (baked into the bundle by `npm run build`).
# VITE_API_URL=https://api.6thsense.dev
